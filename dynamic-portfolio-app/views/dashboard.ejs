<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard | LiquiLink</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="dashboard-page">
    <div class="aurora aurora--one"></div>
    <div class="aurora aurora--two"></div>

    <main class="container dashboard-wrap">
      <section class="dashboard-card">
        <div class="dashboard-top">
          <div>
            <p class="eyebrow">Dashboard</p>
            <h1>Your generated portfolios</h1>
            <p class="plan-chip <%= isPro ? 'plan-chip--pro' : 'plan-chip--basic' %>">
              <%= planLabel %>
            </p>
            <p class="hero-text">
              Welcome, <%= currentUser ? currentUser.fullName : "User" %>. Manage and open your existing portfolio links.
            </p>
          </div>
          <div class="dashboard-actions">
            <a href="/form.html" class="btn btn-primary">Create New Portfolio</a>
            <form action="/logout" method="POST">
              <button type="submit" class="btn btn-ghost">Logout</button>
            </form>
            <form
              action="/delete-account"
              method="POST"
              onsubmit="return confirm('This will permanently delete your account and all associated portfolios. Continue?');"
            >
              <button type="submit" class="btn btn-danger">Delete account</button>
            </form>
          </div>
        </div>

        <% if (!isPro) { %>
        <div class="plan-banner-basic">
          <p>
            You cannot create more than 1 portfolio and you can't edit your existing portfolio, upgrade to pro now to unlock amazing perks!
          </p>
        </div>
        <% } %>

        <% if (!portfolios.length) { %>
        <div class="empty-state">
          <p>No portfolios yet. Create your first one now.</p>
        </div>
        <% } else { %>
        <div class="dashboard-list">
          <% portfolios.forEach((item) => { %>
          <article class="dashboard-item">
            <div>
              <h3><%= item.fullName %></h3>
              <p class="muted-line"><%= item.role %></p>
              <p class="muted-line">URL: /<%= item.slug %></p>
            </div>
            <div class="dashboard-item-actions">
              <a href="/<%= item.slug %>" class="btn btn-ghost">Open</a>
              <a
                href="/portfolio/<%= item.portfolioId || item.slug || item.id %>/edit"
                class="btn btn-ghost"
              >
                Edit
              </a>
            </div>
          </article>
          <% }) %>
        </div>
        <% } %>
      </section>
    </main>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard | LiquiLink</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="dashboard-page">
    <div class="aurora aurora--one"></div>
    <div class="aurora aurora--two"></div>

    <main class="container dashboard-wrap">
      <section class="dashboard-card">
        <div class="dashboard-top">
          <div>
            <p class="eyebrow">Dashboard</p>
            <h1>Your generated portfolios</h1>
            <p class="plan-chip <%= isPaidPlan ? 'plan-chip--pro' : 'plan-chip--basic' %>">
              <%= planLabel %>
            </p>
            <p class="hero-text">
              Welcome, <%= currentUser ? currentUser.fullName : "User" %>. Manage and open your existing portfolio links.
            </p>
            <nav class="dashboard-tabs" aria-label="Dashboard navigation">
              <a href="/dashboard" class="dashboard-tab is-active">Portfolios</a>
              <a href="/analytics" class="dashboard-tab">Analytics</a>
            </nav>
          </div>
          <div class="dashboard-actions">
            <a href="/form.html" class="btn btn-primary" id="createPortfolioBtn">Create New Portfolio</a>
            <a href="<%= viewAllPlansHref %>" class="btn btn-ghost">View All Plans</a>
            <% if (showRestorePreviousPlanBtn) { %>
            <form action="/account/restore-previous-plan" method="POST">
              <input type="hidden" name="next" value="/dashboard" />
              <button type="submit" class="btn btn-primary">
                Go Back to Previous Plan (<%= restorePlanLabel %>)
              </button>
            </form>
            <% } %>
            <form action="/logout" method="POST">
              <button type="submit" class="btn btn-ghost">Logout</button>
            </form>
            <form
              action="/delete-account"
              method="POST"
              onsubmit="return confirm('This will permanently delete your account and all associated portfolios. Continue?');"
            >
              <button type="submit" class="btn btn-danger">Delete account</button>
            </form>
          </div>
        </div>

        <% if (!canCustomize) { %>
        <div class="plan-banner-basic">
          <p>
            Free plan: you can create 1 portfolio and edit content fields. Theme, layout, colors, and typography are Plus features.
          </p>
          <a href="/pricing?reason=upgrade&plan=plus&next=%2Fdashboard" class="btn btn-primary">View all plans</a>
        </div>
        <% } %>

        <% if (!portfolios.length) { %>
        <div class="empty-state">
          <p>No portfolios yet. Create your first one now.</p>
        </div>
        <% } else { %>
        <div class="dashboard-list">
          <% portfolios.forEach((item) => { %>
          <article class="dashboard-item">
            <div>
              <h3><%= item.fullName %></h3>
              <p class="muted-line"><%= item.role %></p>
              <p class="muted-line">URL: /<%= item.slug %></p>
              <div class="dashboard-item-metrics">
                <span class="dashboard-metric" title="Visits to your public page">
                  <i class="fa-solid fa-eye" aria-hidden="true"></i>
                  <%= item.analytics && typeof item.analytics.views === "number" ? item.analytics.views : 0 %> views
                </span>
                <span class="dashboard-metric" title="Clicks on email and social links">
                  <i class="fa-solid fa-arrow-pointer" aria-hidden="true"></i>
                  <%= item.analytics && typeof item.analytics.linkClicks === "number" ? item.analytics.linkClicks : 0 %> link clicks
                </span>
              </div>
            </div>
            <div class="dashboard-item-actions">
              <a href="/<%= item.slug %>" class="btn btn-ghost">Open</a>
              <a
                href="/portfolio/<%= item.portfolioId || item.slug || item.id %>/edit"
                class="btn btn-ghost"
              >
                Edit
              </a>
              <% if (canUseBuilder) { %>
              <a
                href="/portfolio/<%= item.portfolioId || item.slug || item.id %>/builder"
                class="btn btn-ghost"
              >
                Builder
              </a>
              <% } else { %>
              <a
                href="/pricing?reason=builder&plan=pro&next=<%= encodeURIComponent('/portfolio/' + (item.portfolioId || item.slug || item.id) + '/builder') %>"
                class="btn btn-ghost"
              >
                Pro Builder
              </a>
              <% } %>
              <form
                action="/portfolio/<%= item.portfolioId || item.slug || item.id %>/delete"
                method="POST"
                onsubmit="return confirm('Delete this portfolio permanently?');"
              >
                <button type="submit" class="btn btn-danger">Delete</button>
              </form>
            </div>
          </article>
          <% }) %>
        </div>
        <% } %>
      </section>
    </main>
    <!-- Upgrade modal for Free users hitting portfolio limit -->
    <div id="upgradeModal" style="
      display:none;position:fixed;inset:0;z-index:9000;
      background:rgba(0,0,0,0.6);backdrop-filter:blur(6px);
      align-items:center;justify-content:center;
    ">
      <section style="
        background:#0d1526;border:1px solid rgba(136,179,255,0.22);
        border-radius:1.25rem;padding:2rem 2rem 1.5rem;max-width:420px;width:90%;
        box-shadow:0 8px 48px rgba(0,0,0,0.6);
      " role="dialog" aria-modal="true" aria-labelledby="upgradeModalTitle">
        <p class="eyebrow">Free plan limit</p>
        <h2 id="upgradeModalTitle" style="margin:0.3rem 0 0.65rem;">Unlock unlimited portfolios</h2>
        <p class="hero-text" style="margin-bottom:1.25rem;">
          Free plan includes 1 portfolio. Upgrade to Plus to create unlimited portfolios, unlock themes, custom colors, and more.
        </p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="/pricing?reason=create&plan=plus&next=%2Fform.html" class="btn btn-primary">See all plans</a>
          <button type="button" class="btn btn-ghost" id="upgradeModalClose">Not now</button>
        </div>
      </section>
    </div>
    <script>
      (function () {
        var isPaid = <%= isPaidPlan ? 'true' : 'false' %>;
        var portfolioCount = <%= portfolios.length %>;
        var btn = document.getElementById('createPortfolioBtn');
        var modal = document.getElementById('upgradeModal');
        var closeBtn = document.getElementById('upgradeModalClose');
        if (!btn || !modal) return;
        if (!isPaid && portfolioCount >= 1) {
          btn.addEventListener('click', function (e) {
            e.preventDefault();
            modal.style.display = 'flex';
          });
        }
        if (closeBtn) {
          closeBtn.addEventListener('click', function () { modal.style.display = 'none'; });
        }
        modal.addEventListener('click', function (e) {
          if (e.target === modal) modal.style.display = 'none';
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && modal.style.display === 'flex') modal.style.display = 'none';
        });
      })();
    </script>
    <script src="/liquid-glass.js?v=6"></script>
  </body>
</html>

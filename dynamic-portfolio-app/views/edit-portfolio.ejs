<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Portfolio | LiquiLink</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      .pro-locked-block {
        position: relative;
      }
      .pro-locked-block::before {
        content: "Pro";
        position: absolute;
        top: -0.5rem;
        right: 0;
        z-index: 4;
        font-size: 0.72rem;
        font-weight: 700;
        padding: 0.15rem 0.45rem;
        border-radius: 999px;
        background: rgba(255, 80, 80, 0.16);
        border: 1px solid rgba(255, 80, 80, 0.38);
        color: #ff9f9f;
        pointer-events: none;
      }
      .pro-locked-block.is-locked-hit {
        outline: 2px solid rgba(255, 88, 88, 0.9);
        outline-offset: 8px;
        border-radius: 0.75rem;
      }
      .pro-lock-overlay {
        position: absolute;
        inset: 0;
        z-index: 3;
        margin: 0;
        padding: 0;
        border: none;
        border-radius: 0.75rem;
        background: transparent;
        cursor: pointer;
      }
      #proLockModal[hidden] {
        display: none !important;
        pointer-events: none !important;
        visibility: hidden !important;
      }
      #proLockModal:not([hidden]) {
        display: grid;
        visibility: visible;
      }
    </style>
  </head>
  <body class="form-page form-page--with-live-preview">
    <div class="aurora aurora--one"></div>
    <div class="aurora aurora--two"></div>
    <main class="container form-wrap">
      <div class="form-editor-shell">
        <div class="form-editor-main">
      <section class="form-card">
        <div class="form-topbar">
          <div class="form-topbar-cluster">
            <a href="/dashboard" class="btn btn-ghost">Back</a>
            <% if (canUseBuilder) { %>
            <a href="/portfolio/<%= portfolio.portfolioId %>/builder" class="btn btn-ghost">Open Pro Builder</a>
            <% } %>
            <p class="form-user">Editing: <%= portfolio.fullName %></p>
          </div>
        </div>

        <p class="eyebrow">Edit Portfolio</p>
        <h1>Update your portfolio content</h1>
        <% if (!canCustomize) { %>
        <p class="hero-text">
          Free plan: you can edit content fields and add new entries. Theme, layout, color, and typography are Plus-only.
        </p>
        <% } %>

        <form action="/portfolio/<%= portfolio.portfolioId %>/edit" method="POST" enctype="multipart/form-data" class="portfolio-form" id="editPortfolioForm">
          <input type="hidden" name="sectionOrder" id="sectionOrderField" value="<%= portfolio.sectionOrder %>" />

          <div class="grid-2">
            <label>
              Full Name
              <input type="text" name="fullName" value="<%= portfolio.fullName %>" required />
            </label>
            <label>
              Role
              <input type="text" name="role" value="<%= portfolio.role %>" required />
            </label>
          </div>

          <div class="<%= canCustomize ? '' : 'pro-locked-block' %>" data-pro-feature="Theme preset and color scheme">
          <div class="grid-2">
            <label>
              Theme preset
              <select id="themePreset" name="theme">
                <option value="dark" <%= portfolio.theme === "dark" ? "selected" : "" %>>Dark</option>
                <option value="light" <%= portfolio.theme === "light" ? "selected" : "" %>>Light</option>
              </select>
              <span class="hero-text" style="display:block;margin-top:0.35rem;font-size:0.86rem;font-weight:500;"
                >Sets page contrast helpers and fills color fields below.</span
              >
            </label>
            <label>
              Style theme
              <select name="styleTheme">
                <option value="liquid-glass" <%= portfolio.styleTheme === "liquid-glass" ? "selected" : "" %>>Liquid Glass (default)</option>
                <option value="glow" <%= portfolio.styleTheme === "glow" || portfolio.styleTheme === "anime-manga" ? "selected" : "" %>>Glow</option>
              </select>
            </label>
          </div>

          <p class="eyebrow" style="margin-top:0.5rem;">Colors</p>
          <div class="color-field-grid">
            <label>
              Background
              <span class="color-input-row">
                <input type="color" id="pick-colorBg" data-hex-field="colorBg" value="<%= portfolio.colorBg %>" />
                <input type="text" name="colorBg" id="colorBg" value="<%= portfolio.colorBg %>" pattern="#[0-9A-Fa-f]{6}" maxlength="7" required />
              </span>
            </label>
            <label>
              Text
              <span class="color-input-row">
                <input type="color" id="pick-colorText" data-hex-field="colorText" value="<%= portfolio.colorText %>" />
                <input type="text" name="colorText" id="colorText" value="<%= portfolio.colorText %>" pattern="#[0-9A-Fa-f]{6}" maxlength="7" required />
              </span>
            </label>
            <label>
              Accent
              <span class="color-input-row">
                <input type="color" id="pick-colorAccent" data-hex-field="colorAccent" value="<%= portfolio.colorAccent %>" />
                <input type="text" name="colorAccent" id="colorAccent" value="<%= portfolio.colorAccent %>" pattern="#[0-9A-Fa-f]{6}" maxlength="7" required />
              </span>
            </label>
            <label>
              Card background
              <span class="color-input-row">
                <input type="color" id="pick-colorCard" data-hex-field="colorCard" value="<%= portfolio.colorCard %>" />
                <input type="text" name="colorCard" id="colorCard" value="<%= portfolio.colorCard %>" pattern="#[0-9A-Fa-f]{6}" maxlength="7" required />
              </span>
            </label>
          </div>

          <% if (!canCustomize) { %>
          <button
            type="button"
            class="pro-lock-overlay"
            aria-label="Theme and colors are Plus only. Click for upgrade options."
          ></button>
          <% } %>
          </div>

          <div class="<%= canCustomize ? '' : 'pro-locked-block' %>" data-pro-feature="Portfolio layout">
          <p class="eyebrow" style="margin-top:0.5rem;">Layout</p>
          <label>
            Section order (drag to reorder)
            <ul class="section-order-list" id="sectionOrderList" aria-label="Section order">
              <% 
                var labels = { hero: "Hero", about: "About", projects: "Projects", experience: "Experience" };
                var orderParts = (portfolio.sectionOrder || "").split(",").map(function(s){ return s.trim(); }).filter(Boolean);
                if (orderParts.length === 0) orderParts = ["hero", "about", "projects", "experience"];
                orderParts.forEach(function(sec) { 
              %>
              <li class="section-order-item" draggable="true" data-section="<%= sec %>">
                <i class="fa-solid fa-grip-vertical" aria-hidden="true"></i>
                <span><%= labels[sec] || sec %></span>
              </li>
              <% }); %>
            </ul>
          </label>

          <div class="grid-2">
            <label>
              Hero layout
              <select name="heroLayout">
                <option value="split" <%= portfolio.heroLayout === "split" ? "selected" : "" %>>Text left · card right</option>
                <option value="split-reverse" <%= portfolio.heroLayout === "split-reverse" ? "selected" : "" %>>Card left · text right</option>
                <option value="text-only" <%= portfolio.heroLayout === "text-only" ? "selected" : "" %>>Text only (full width)</option>
                <option value="card-only" <%= portfolio.heroLayout === "card-only" ? "selected" : "" %>>Card only (full width)</option>
                <option value="stacked" <%= portfolio.heroLayout === "stacked" ? "selected" : "" %>>Stacked · centered</option>
              </select>
            </label>
            <label>
              About cards
              <select name="aboutLayout">
                <option value="grid-3" <%= portfolio.aboutLayout === "grid-3" ? "selected" : "" %>>Grid · 3 columns</option>
                <option value="grid-2" <%= portfolio.aboutLayout === "grid-2" ? "selected" : "" %>>Grid · 2 columns</option>
                <option value="scroll" <%= portfolio.aboutLayout === "scroll" ? "selected" : "" %>>Horizontal scroll</option>
              </select>
            </label>
            <label>
              Projects
              <select name="projectsLayout">
                <option value="cols-3" <%= portfolio.projectsLayout === "cols-3" ? "selected" : "" %>>Grid · 3 columns</option>
                <option value="cols-2" <%= portfolio.projectsLayout === "cols-2" ? "selected" : "" %>>Grid · 2 columns</option>
                <option value="list" <%= portfolio.projectsLayout === "list" ? "selected" : "" %>>List</option>
              </select>
            </label>
            <label>
              Experience
              <select name="experienceLayout">
                <option value="timeline" <%= portfolio.experienceLayout === "timeline" ? "selected" : "" %>>Vertical timeline</option>
                <option value="grid" <%= portfolio.experienceLayout === "grid" ? "selected" : "" %>>Card grid</option>
                <option value="compact" <%= portfolio.experienceLayout === "compact" ? "selected" : "" %>>Compact list</option>
              </select>
            </label>
            <label>
              Top navigation
              <select name="showNavbar">
                <option value="1" <%= portfolio.showNavbar === "1" ? "selected" : "" %>>Show sticky navbar</option>
                <option value="0" <%= portfolio.showNavbar === "0" ? "selected" : "" %>>Hide navbar</option>
              </select>
            </label>
            <label>
              Footer
              <select name="showFooterContact">
                <option value="1" <%= portfolio.showFooterContact === "1" ? "selected" : "" %>>Show contact section</option>
                <option value="0" <%= portfolio.showFooterContact === "0" ? "selected" : "" %>>Hide contact section</option>
              </select>
            </label>
          </div>

          <% if (!canCustomize) { %>
          <button
            type="button"
            class="pro-lock-overlay"
            aria-label="Layout options are Plus only. Click for upgrade options."
          ></button>
          <% } %>
          </div>

          <div class="<%= canCustomize ? '' : 'pro-locked-block' %>" data-pro-feature="Typography options">
          <p class="eyebrow" style="margin-top:0.5rem;">Typography</p>
          <div class="grid-2">
            <label>
              Font
              <select name="fontFamily">
                <option value="inter" <%= portfolio.fontFamily === "inter" ? "selected" : "" %>>Inter</option>
                <option value="poppins" <%= portfolio.fontFamily === "poppins" ? "selected" : "" %>>Poppins</option>
                <option value="roboto" <%= portfolio.fontFamily === "roboto" ? "selected" : "" %>>Roboto</option>
                <option value="playfair-display" <%= portfolio.fontFamily === "playfair-display" ? "selected" : "" %>>Playfair Display</option>
                <option value="space-grotesk" <%= portfolio.fontFamily === "space-grotesk" ? "selected" : "" %>>Space Grotesk</option>
              </select>
            </label>
            <label>
              Font size
              <select name="fontScale">
                <option value="small" <%= portfolio.fontScale === "small" ? "selected" : "" %>>Small</option>
                <option value="medium" <%= portfolio.fontScale === "medium" ? "selected" : "" %>>Medium (default)</option>
                <option value="large" <%= portfolio.fontScale === "large" ? "selected" : "" %>>Large</option>
              </select>
            </label>
          </div>
          <% if (!canCustomize) { %>
          <button
            type="button"
            class="pro-lock-overlay"
            aria-label="Typography is Plus only. Click for upgrade options."
          ></button>
          <% } %>
          </div>

          <label>
            Headline
            <input type="text" name="headline" value="<%= portfolio.headline %>" required />
          </label>

          <label>
            Hero Description
            <textarea name="heroText" rows="3" required><%= portfolio.heroText %></textarea>
          </label>

          <div class="grid-2">
            <label>
              Profile Picture URL
              <input type="text" name="profileImageUrl" value="<%= portfolio.profileImageUrl || '' %>" />
            </label>
            <label>
              Company Logo URL
              <input type="text" name="companyLogoUrl" value="<%= portfolio.companyLogoUrl || '' %>" />
            </label>
            <label>
              Profile Picture Upload
              <input type="file" name="profileImageFile" accept="image/*" />
            </label>
            <label>
              Company Logo Upload
              <input type="file" name="companyLogoFile" accept="image/*" />
            </label>
          </div>

          <div class="grid-2">
            <label>
              Shipping Label
              <input type="text" name="shippingTitle" value="<%= portfolio.shippingTitle %>" />
            </label>
            <label>
              Shipping Heading
              <input type="text" name="shippingHeading" value="<%= portfolio.shippingHeading %>" />
            </label>
          </div>

          <label>
            Shipping Description
            <textarea name="shippingDescription" rows="3"><%= portfolio.shippingDescription %></textarea>
          </label>

          <label>
            Shipping Bullet Points (one per line)
            <textarea name="shippingPoints" rows="3"><%= portfolio.shippingPointsText %></textarea>
          </label>

          <label>
            About Cards
            <div id="aboutEntriesEdit" class="experience-entry-list">
              <% (portfolio.aboutCards || []).forEach((item) => { %>
              <article class="experience-entry-item">
                <div class="experience-entry-grid">
                  <input type="text" name="aboutTitle" value="<%= item.title || '' %>" readonly />
                  <textarea name="aboutDescription" rows="2" readonly><%= item.description || '' %></textarea>
                </div>
                <div class="experience-entry-actions">
                  <button type="button" class="btn btn-ghost experience-edit-btn">Edit</button>
                  <button type="button" class="btn btn-ghost experience-remove-btn">
                    <i class="fa-solid fa-minus" aria-hidden="true"></i>
                    Remove
                  </button>
                </div>
              </article>
              <% }) %>
            </div>
            <button type="button" class="btn btn-ghost experience-add-btn" id="addAboutEdit">
              <i class="fa-solid fa-plus" aria-hidden="true"></i>
              Add About Card
            </button>
          </label>

          <label>
            Projects
            <div id="projectEntriesEdit" class="experience-entry-list">
              <% (portfolio.projects || []).forEach((item) => { %>
              <article class="experience-entry-item">
                <div class="experience-entry-grid">
                  <input type="text" name="projectTitle" value="<%= item.title || '' %>" readonly />
                  <input type="text" name="projectPlatform" value="<%= item.platform || '' %>" readonly />
                  <textarea name="projectDescription" rows="2" readonly><%= item.description || '' %></textarea>
                </div>
                <div class="experience-entry-actions">
                  <button type="button" class="btn btn-ghost experience-edit-btn">Edit</button>
                  <button type="button" class="btn btn-ghost experience-remove-btn">
                    <i class="fa-solid fa-minus" aria-hidden="true"></i>
                    Remove
                  </button>
                </div>
              </article>
              <% }) %>
            </div>
            <button type="button" class="btn btn-ghost experience-add-btn" id="addProjectEdit">
              <i class="fa-solid fa-plus" aria-hidden="true"></i>
              Add Project
            </button>
          </label>

          <label>
            Experience (optional)
            <div id="experienceEntriesEdit" class="experience-entry-list">
              <% (portfolio.experiences || []).forEach((item) => { %>
              <article class="experience-entry-item">
                <div class="experience-entry-grid">
                  <input type="text" name="experiencePeriod" value="<%= item.period || '' %>" readonly />
                  <input type="text" name="experienceTitle" value="<%= item.title || '' %>" readonly />
                  <textarea name="experienceDescription" rows="2" readonly><%= item.description || '' %></textarea>
                </div>
                <div class="experience-entry-actions">
                  <button type="button" class="btn btn-ghost experience-edit-btn">Edit</button>
                  <button type="button" class="btn btn-ghost experience-remove-btn">
                    <i class="fa-solid fa-minus" aria-hidden="true"></i>
                    Remove
                  </button>
                </div>
              </article>
              <% }) %>
            </div>
            <button type="button" class="btn btn-ghost experience-add-btn" id="addExperienceEdit">
              <i class="fa-solid fa-plus" aria-hidden="true"></i>
              Add Experience
            </button>
          </label>

          <div class="grid-2">
            <label>
              Email
              <input type="email" name="email" value="<%= portfolio.email %>" />
            </label>
            <label>
              LinkedIn URL
              <input type="url" name="linkedin" value="<%= portfolio.linkedin %>" />
            </label>
            <label>
              YouTube URL
              <input type="url" name="youtube" value="<%= portfolio.youtube %>" />
            </label>
            <label>
              Instagram URL
              <input type="url" name="instagram" value="<%= portfolio.instagram %>" />
            </label>
            <label>
              Twitter/X URL
              <input type="url" name="twitter" value="<%= portfolio.twitter %>" />
            </label>
            <label>
              GitHub URL
              <input type="url" name="github" value="<%= portfolio.github %>" />
            </label>
          </div>

          <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
            Save Changes
          </button>
        </form>
      </section>
        </div>
        <aside class="form-editor-preview" aria-label="Live portfolio preview">
          <div class="live-preview-panel form-card" style="padding:1rem 1.1rem;">
            <div class="live-preview-header">
              <div>
                <p class="eyebrow">Live preview</p>
                <p class="live-preview-hint">Updates as you type</p>
              </div>
              <button type="button" class="btn btn-ghost" id="openPreviewTabBtn" style="flex-shrink:0;">
                Open in new tab
              </button>
            </div>
            <iframe
              class="live-preview-frame"
              id="portfolioLivePreview"
              title="Portfolio live preview"
              src="about:blank"
            ></iframe>
          </div>
        </aside>
      </div>
    </main>
    <div class="modal-backdrop" id="proLockModal" hidden style="display: none">
      <section class="upgrade-modal" role="dialog" aria-modal="true" aria-labelledby="proLockTitle">
        <p class="eyebrow">Plus feature</p>
        <h2 id="proLockTitle" style="margin:0.3rem 0 0.65rem;">Unlock customization controls</h2>
        <p class="hero-text" id="proLockText" style="margin:0;">
          This setting is available only on Plus. Upgrade now to unlock all customization options.
        </p>
        <div class="upgrade-modal-actions">
          <a class="btn btn-primary" id="proLockUpgradeBtn" href="/pricing?reason=edit&plan=plus">See all plans</a>
          <button type="button" class="btn btn-ghost" id="proLockCloseBtn">Not now</button>
        </div>
      </section>
    </div>
    <template id="experienceEntryTemplateEdit">
      <article class="experience-entry-item">
        <div class="experience-entry-grid">
          <input type="text" name="experiencePeriod" placeholder="Period (e.g. 2022 - Present)" />
          <input type="text" name="experienceTitle" placeholder="Title (e.g. Senior Developer, Apple)" />
          <textarea name="experienceDescription" rows="2" placeholder="Description"></textarea>
        </div>
        <div class="experience-entry-actions">
          <button type="button" class="btn btn-ghost experience-edit-btn">Edit</button>
          <button type="button" class="btn btn-ghost experience-remove-btn">
            <i class="fa-solid fa-minus" aria-hidden="true"></i>
            Remove
          </button>
        </div>
      </article>
    </template>
    <template id="aboutEntryTemplateEdit">
      <article class="experience-entry-item">
        <div class="experience-entry-grid">
          <input type="text" name="aboutTitle" placeholder="About title (e.g. Design + Code)" />
          <textarea name="aboutDescription" rows="2" placeholder="About description"></textarea>
        </div>
        <div class="experience-entry-actions">
          <button type="button" class="btn btn-ghost experience-edit-btn">Edit</button>
          <button type="button" class="btn btn-ghost experience-remove-btn">
            <i class="fa-solid fa-minus" aria-hidden="true"></i>
            Remove
          </button>
        </div>
      </article>
    </template>
    <template id="projectEntryTemplateEdit">
      <article class="experience-entry-item">
        <div class="experience-entry-grid">
          <input type="text" name="projectTitle" placeholder="Project title" />
          <input type="text" name="projectPlatform" placeholder="Platform (e.g. iOS, Web)" />
          <textarea name="projectDescription" rows="2" placeholder="Project description"></textarea>
        </div>
        <div class="experience-entry-actions">
          <button type="button" class="btn btn-ghost experience-edit-btn">Edit</button>
          <button type="button" class="btn btn-ghost experience-remove-btn">
            <i class="fa-solid fa-minus" aria-hidden="true"></i>
            Remove
          </button>
        </div>
      </article>
    </template>
    <script src="/portfolio-live-preview.js"></script>
    <script>
      (function () {
        var THEME_PRESETS = {
          dark: { colorBg: "#05070d", colorText: "#f5f8ff", colorAccent: "#88b3ff", colorCard: "#151d30" },
          light: { colorBg: "#eef3ff", colorText: "#0f1a2f", colorAccent: "#356ed5", colorCard: "#ffffff" }
        };

        function normHex(v) {
          if (!v || typeof v !== "string") return "#000000";
          var s = v.trim();
          if (!s.startsWith("#")) s = "#" + s;
          if (!/^#[0-9A-Fa-f]{6}$/.test(s)) return "#000000";
          return s.toLowerCase();
        }

        function wireColorPair(hexId, pickerId) {
          var hexEl = document.getElementById(hexId);
          var pickEl = document.getElementById(pickerId);
          if (!hexEl || !pickEl) return;
          function fromHex() {
            var h = normHex(hexEl.value);
            pickEl.value = h;
            hexEl.value = h;
          }
          function fromPick() {
            hexEl.value = normHex(pickEl.value);
          }
          hexEl.addEventListener("input", fromHex);
          hexEl.addEventListener("change", fromHex);
          pickEl.addEventListener("input", fromPick);
          pickEl.addEventListener("change", fromPick);
        }

        wireColorPair("colorBg", "pick-colorBg");
        wireColorPair("colorText", "pick-colorText");
        wireColorPair("colorAccent", "pick-colorAccent");
        wireColorPair("colorCard", "pick-colorCard");

        var themeSel = document.getElementById("themePreset");
        if (themeSel) {
          themeSel.addEventListener("change", function () {
            var p = THEME_PRESETS[themeSel.value];
            if (!p) return;
            ["colorBg", "colorText", "colorAccent", "colorCard"].forEach(function (k) {
              var h = document.getElementById(k);
              var pick = document.getElementById("pick-" + k);
              if (h) h.value = p[k];
              if (pick) pick.value = p[k];
            });
          });
        }

        var list = document.getElementById("sectionOrderList");
        var field = document.getElementById("sectionOrderField");
        var dragEl = null;

        function syncOrderField() {
          if (!list || !field) return;
          var ids = [].map.call(list.querySelectorAll(".section-order-item"), function (li) {
            return li.getAttribute("data-section");
          });
          field.value = ids.join(",");
        }

        if (list) {
          list.addEventListener("dragstart", function (e) {
            var t = e.target.closest(".section-order-item");
            if (!t) return;
            dragEl = t;
            e.dataTransfer.effectAllowed = "move";
            try {
              e.dataTransfer.setData("text/plain", t.getAttribute("data-section"));
            } catch (err) {}
            t.style.opacity = "0.55";
          });

          list.addEventListener("dragend", function (e) {
            var t = e.target.closest(".section-order-item");
            if (t) t.style.opacity = "";
            dragEl = null;
          });

          list.addEventListener("dragover", function (e) {
            e.preventDefault();
            var t = e.target.closest(".section-order-item");
            if (!t || !dragEl || t === dragEl) return;
            var rect = t.getBoundingClientRect();
            var before = e.clientY < rect.top + rect.height / 2;
            if (before) list.insertBefore(dragEl, t);
            else list.insertBefore(dragEl, t.nextSibling);
          });

          list.addEventListener("drop", function (e) {
            e.preventDefault();
            syncOrderField();
          });
        }

        var formEl = document.querySelector("form#editPortfolioForm");
        if (!formEl) return;
        var canCustomizeUser = <%= canCustomize ? "true" : "false" %>;
        var proLockModal = document.getElementById("proLockModal");
        var proLockText = document.getElementById("proLockText");
        var proLockCloseBtn = document.getElementById("proLockCloseBtn");
        var proLockUpgradeBtn = document.getElementById("proLockUpgradeBtn");
        formEl.addEventListener("submit", syncOrderField);
        syncOrderField();

        var openPreviewTabBtn = document.getElementById("openPreviewTabBtn");
        var aboutListEl = document.getElementById("aboutEntriesEdit");
        var aboutAddBtn = document.getElementById("addAboutEdit");
        var aboutTpl = document.getElementById("aboutEntryTemplateEdit");
        var projectListEl = document.getElementById("projectEntriesEdit");
        var projectAddBtn = document.getElementById("addProjectEdit");
        var projectTpl = document.getElementById("projectEntryTemplateEdit");
        var expListEl = document.getElementById("experienceEntriesEdit");
        var expAddBtn = document.getElementById("addExperienceEdit");
        var expTpl = document.getElementById("experienceEntryTemplateEdit");

        function openProModal() {
          if (!proLockModal) return;
          proLockModal.removeAttribute("hidden");
          proLockModal.style.display = "grid";
          proLockModal.style.visibility = "visible";
        }

        function closeProModal() {
          if (!proLockModal) return;
          proLockModal.setAttribute("hidden", "");
          proLockModal.style.display = "none";
          proLockModal.style.visibility = "hidden";
        }

        function showProLock(block) {
          if (!block) return;
          block.classList.add("is-locked-hit");
          setTimeout(function () {
            block.classList.remove("is-locked-hit");
          }, 850);
          if (!proLockModal) return;
          var feature = block.getAttribute("data-pro-feature") || "This setting";
          if (proLockText) {
            proLockText.textContent =
              feature +
              " is available only on Plus. Upgrade now to unlock full customization.";
          }
          openProModal();
        }

        if (!canCustomizeUser) {
          if (proLockUpgradeBtn) {
            proLockUpgradeBtn.setAttribute(
              "href",
              "/pricing?reason=edit&plan=plus&next=" + encodeURIComponent(window.location.pathname)
            );
          }
          [].slice.call(document.querySelectorAll(".pro-locked-block")).forEach(function (block) {
            block
              .querySelectorAll("input, select, textarea, button:not(.pro-lock-overlay), .section-order-item")
              .forEach(function (el) {
                el.setAttribute("tabindex", "-1");
              });
          });
          [].slice.call(document.querySelectorAll(".pro-lock-overlay")).forEach(function (btn) {
            btn.addEventListener("click", function (e) {
              e.preventDefault();
              e.stopPropagation();
              showProLock(btn.closest(".pro-locked-block"));
            });
          });
          if (proLockCloseBtn) {
            proLockCloseBtn.addEventListener("click", function (e) {
              e.preventDefault();
              e.stopPropagation();
              closeProModal();
            });
          }
          if (proLockModal) {
            proLockModal.addEventListener("click", function (e) {
              if (e.target === proLockModal) closeProModal();
            });
          }
          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape" && proLockModal && !proLockModal.hasAttribute("hidden")) {
              closeProModal();
            }
          });
        }

        function setEditable(item, editable) {
          var fields = item.querySelectorAll("input, textarea");
          fields.forEach(function (field) { field.readOnly = !editable; });
          var editBtn = item.querySelector(".experience-edit-btn");
          if (editBtn) editBtn.textContent = editable ? "Done" : "Edit";
        }

        function bindItem(item) {
          var editBtn = item.querySelector(".experience-edit-btn");
          var removeBtn = item.querySelector(".experience-remove-btn");
          if (editBtn) {
            editBtn.addEventListener("click", function () {
              var firstInput = item.querySelector("input");
              var isReadOnly = firstInput ? firstInput.readOnly : false;
              setEditable(item, isReadOnly);
            });
          }
          if (removeBtn) {
            removeBtn.addEventListener("click", function () {
              item.remove();
            });
          }
        }

        function setupEditableList(listEl, addBtn, tpl, initialReadOnly) {
          if (!listEl || !tpl) return;
          [].slice.call(listEl.querySelectorAll(".experience-entry-item")).forEach(function (item) {
            bindItem(item);
            setEditable(item, !initialReadOnly);
          });
          if (!addBtn) return;
          addBtn.addEventListener("click", function () {
            var node = tpl.content.firstElementChild.cloneNode(true);
            listEl.appendChild(node);
            bindItem(node);
            setEditable(node, true);
          });
        }

        setupEditableList(aboutListEl, aboutAddBtn, aboutTpl, true);
        setupEditableList(projectListEl, projectAddBtn, projectTpl, true);
        setupEditableList(expListEl, expAddBtn, expTpl, true);

        if (openPreviewTabBtn && window.openPortfolioPreviewInNewTab) {
          openPreviewTabBtn.addEventListener("click", function () {
            window.openPortfolioPreviewInNewTab(formEl, "edit", syncOrderField);
          });
        }

        var previewIframe = document.getElementById("portfolioLivePreview");
        if (previewIframe && window.attachPortfolioLivePreview) {
          window.attachPortfolioLivePreview({
            form: formEl,
            iframe: previewIframe,
            mode: "edit",
            beforeRead: syncOrderField
          });
        }
      })();
    </script>
    <script src="/custom-cursor.js" defer></script>
  </body>
</html>

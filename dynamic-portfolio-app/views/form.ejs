<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Your Dynamic Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      .builder-live-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(360px, 44%);
        gap: 1rem;
        align-items: start;
      }
      .builder-pane {
        min-width: 0;
      }
      .builder-preview-pane {
        position: sticky;
        top: 1rem;
      }
      .builder-preview-pane h3 {
        margin: 0 0 0.45rem;
        font-size: 0.95rem;
        color: var(--muted);
      }
      .builder-preview-pane .live-preview-frame {
        min-height: 82vh;
      }
      @media (max-width: 1080px) {
        .builder-live-layout {
          grid-template-columns: 1fr;
        }
        .builder-preview-pane {
          position: static;
        }
        .builder-preview-pane .live-preview-frame {
          min-height: 64vh;
        }
      }
    </style>
  </head>
  <body class="form-page">
    <div class="aurora aurora--one"></div>
    <div class="aurora aurora--two"></div>

    <main class="container form-wrap">
      <section class="form-card">
        <div class="form-topbar">
          <p class="form-user">Logged in as <%= currentUser ? currentUser.fullName : "User" %></p>
          <form action="/logout" method="POST">
            <button type="submit" class="btn btn-ghost">Logout</button>
          </form>
        </div>

        <p class="eyebrow">Dynamic Portfolio Generator</p>
        <h1>Create your Apple-style portfolio</h1>
        <p class="hero-text">
          Fill this form and submit. Your data is saved to a database file and
          you are redirected to your own portfolio page.
        </p>

        <div class="builder-live-layout">
        <div class="builder-pane">
        <form action="/create" method="POST" enctype="multipart/form-data" class="portfolio-form" id="createPortfolioForm">
          <div class="grid-2">
            <label>
              Full Name
              <input type="text" name="fullName" placeholder="Aria Sterling" required />
            </label>
            <label>
              Role
              <input type="text" name="role" placeholder="Developer at Apple" required />
            </label>
          </div>

          <div class="grid-2">
            <label>
              Theme
              <select name="theme" id="createThemePreset">
                <option value="dark" selected>Dark</option>
                <option value="light">Light</option>
              </select>
            </label>
            <label>
              Style theme
              <select name="styleTheme" id="createStyleTheme">
                <option value="liquid-glass" selected>Liquid Glass (default)</option>
                <option value="glow">Glow</option>
              </select>
            </label>
            <label>
              Layout
              <select name="layoutVariant">
                <option value="default" selected>Default</option>
                <option value="hero-reverse">Hero Reversed</option>
                <option value="projects-first">Projects First</option>
              </select>
            </label>
          </div>

          <p class="eyebrow" style="margin-top:0.3rem;">Colors</p>
          <div class="color-field-grid">
            <label>
              Background
              <span class="color-input-row">
                <input type="color" id="create-pick-colorBg" data-hex-field="create-colorBg" value="#05070d" />
                <input type="text" name="colorBg" id="create-colorBg" value="#05070d" pattern="#[0-9A-Fa-f]{6}" maxlength="7" />
              </span>
            </label>
            <label>
              Text
              <span class="color-input-row">
                <input type="color" id="create-pick-colorText" data-hex-field="create-colorText" value="#f5f8ff" />
                <input type="text" name="colorText" id="create-colorText" value="#f5f8ff" pattern="#[0-9A-Fa-f]{6}" maxlength="7" />
              </span>
            </label>
            <label>
              Accent
              <span class="color-input-row">
                <input type="color" id="create-pick-colorAccent" data-hex-field="create-colorAccent" value="#88b3ff" />
                <input type="text" name="colorAccent" id="create-colorAccent" value="#88b3ff" pattern="#[0-9A-Fa-f]{6}" maxlength="7" />
              </span>
            </label>
            <label>
              Card background
              <span class="color-input-row">
                <input type="color" id="create-pick-colorCard" data-hex-field="create-colorCard" value="#151d30" />
                <input type="text" name="colorCard" id="create-colorCard" value="#151d30" pattern="#[0-9A-Fa-f]{6}" maxlength="7" />
              </span>
            </label>
          </div>

          <label>
            Headline
            <input
              type="text"
              name="headline"
              placeholder="Crafting elegant software that feels magical."
              required
            />
          </label>

          <label>
            Hero Description
            <textarea
              name="heroText"
              rows="3"
              placeholder="Short intro paragraph for the hero section"
              required
            ></textarea>
          </label>

          <div class="grid-2">
            <label>
              Profile Picture URL
              <input
                type="text"
                name="profileImageUrl"
                placeholder="https://example.com/profile.jpg or /asset/your-token"
              />
            </label>
            <label>
              Company Logo URL
              <input
                type="text"
                name="companyLogoUrl"
                placeholder="https://example.com/company-logo.png or /asset/your-token"
              />
            </label>
            <label>
              Profile Picture Upload
              <input type="file" name="profileImageFile" accept="image/*" />
            </label>
            <label>
              Company Logo Upload
              <input type="file" name="companyLogoFile" accept="image/*" />
            </label>
          </div>

          <div class="grid-2">
            <label>
              Shipping Label
              <input type="text" name="shippingTitle" placeholder="Now Shipping" />
            </label>
            <label>
              Shipping Heading
              <input type="text" name="shippingHeading" placeholder="Apple Ecosystem Features" />
            </label>
          </div>

          <label>
            Shipping Description
            <textarea
              name="shippingDescription"
              rows="3"
              placeholder="Leading cross-platform experiences for iOS, macOS, and visionOS with clean architecture and consistent performance."
            ></textarea>
          </label>

          <label>
            Shipping Bullet Points (one per line)
            <textarea name="shippingPoints" rows="3" placeholder="Point 1&#10;Point 2&#10;Point 3"></textarea>
          </label>

          <label>
            About Cards
            <div id="aboutEntriesCreate" class="experience-entry-list"></div>
            <button type="button" class="btn btn-ghost experience-add-btn" id="addAboutCreate">
              <i class="fa-solid fa-plus" aria-hidden="true"></i>
              Add About Card
            </button>
          </label>

          <label>
            Projects
            <div id="projectEntriesCreate" class="experience-entry-list"></div>
            <button type="button" class="btn btn-ghost experience-add-btn" id="addProjectCreate">
              <i class="fa-solid fa-plus" aria-hidden="true"></i>
              Add Project
            </button>
          </label>

          <label>
            Experience (optional)
            <div id="experienceEntriesCreate" class="experience-entry-list"></div>
            <button type="button" class="btn btn-ghost experience-add-btn" id="addExperienceCreate">
              <i class="fa-solid fa-plus" aria-hidden="true"></i>
              Add Experience
            </button>
          </label>

          <div class="grid-2">
            <label>
              Email
              <input type="email" name="email" placeholder="you@example.com" />
            </label>
            <label>
              LinkedIn URL
              <input type="url" name="linkedin" placeholder="https://www.linkedin.com/in/yourprofile" />
            </label>
            <label>
              YouTube URL
              <input type="url" name="youtube" placeholder="https://www.youtube.com/@yourchannel" />
            </label>
            <label>
              Instagram URL
              <input type="url" name="instagram" placeholder="https://www.instagram.com/yourprofile" />
            </label>
            <label>
              Twitter/X URL
              <input type="url" name="twitter" placeholder="https://x.com/yourprofile" />
            </label>
            <label>
              GitHub URL
              <input type="url" name="github" placeholder="https://github.com/yourprofile" />
            </label>
          </div>

          <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
            Create My Portfolio
          </button>
        </form>
        </div>
        <div class="builder-preview-pane">
          <h3>Live preview</h3>
          <iframe id="createLivePreviewFrame" title="Live portfolio preview" class="live-preview-frame"></iframe>
        </div>
        </div>
      </section>
    </main>
    <template id="experienceEntryTemplateCreate">
      <article class="experience-entry-item">
        <div class="experience-entry-grid">
          <input type="text" name="experiencePeriod" placeholder="Period (e.g. 2022 - Present)" />
          <input type="text" name="experienceTitle" placeholder="Title (e.g. Senior Developer, Apple)" />
          <textarea name="experienceDescription" rows="2" placeholder="Description"></textarea>
        </div>
        <div class="experience-entry-actions">
          <button type="button" class="btn btn-ghost experience-edit-btn">Edit</button>
          <button type="button" class="btn btn-ghost experience-remove-btn">
            <i class="fa-solid fa-minus" aria-hidden="true"></i>
            Remove
          </button>
        </div>
      </article>
    </template>
    <template id="aboutEntryTemplateCreate">
      <article class="experience-entry-item">
        <div class="experience-entry-grid">
          <input type="text" name="aboutTitle" placeholder="About title (e.g. Design + Code)" />
          <textarea name="aboutDescription" rows="2" placeholder="About description"></textarea>
        </div>
        <div class="experience-entry-actions">
          <button type="button" class="btn btn-ghost experience-edit-btn">Edit</button>
          <button type="button" class="btn btn-ghost experience-remove-btn">
            <i class="fa-solid fa-minus" aria-hidden="true"></i>
            Remove
          </button>
        </div>
      </article>
    </template>
    <template id="projectEntryTemplateCreate">
      <article class="experience-entry-item">
        <div class="experience-entry-grid">
          <input type="text" name="projectTitle" placeholder="Project title" />
          <input type="text" name="projectPlatform" placeholder="Platform (e.g. iOS, Web)" />
          <textarea name="projectDescription" rows="2" placeholder="Project description"></textarea>
        </div>
        <div class="experience-entry-actions">
          <button type="button" class="btn btn-ghost experience-edit-btn">Edit</button>
          <button type="button" class="btn btn-ghost experience-remove-btn">
            <i class="fa-solid fa-minus" aria-hidden="true"></i>
            Remove
          </button>
        </div>
      </article>
    </template>
    <script>
      (function () {
        var THEME_PRESETS = {
          dark: { colorBg: "#05070d", colorText: "#f5f8ff", colorAccent: "#88b3ff", colorCard: "#151d30" },
          light: { colorBg: "#eef3ff", colorText: "#0f1a2f", colorAccent: "#356ed5", colorCard: "#ffffff" }
        };

        function normHex(v) {
          if (!v || typeof v !== "string") return "#000000";
          var s = v.trim();
          if (!s.startsWith("#")) s = "#" + s;
          if (!/^#[0-9A-Fa-f]{6}$/.test(s)) return "#000000";
          return s.toLowerCase();
        }

        function setEditable(item, editable) {
          var fields = item.querySelectorAll("input, textarea");
          fields.forEach(function (field) { field.readOnly = !editable; });
          var editBtn = item.querySelector(".experience-edit-btn");
          if (editBtn) editBtn.textContent = editable ? "Done" : "Edit";
        }

        function bindItem(item) {
          var editBtn = item.querySelector(".experience-edit-btn");
          var removeBtn = item.querySelector(".experience-remove-btn");

          if (editBtn) {
            editBtn.addEventListener("click", function () {
              var isReadOnly = item.querySelector("input").readOnly;
              setEditable(item, isReadOnly);
              refreshLivePreview();
            });
          }
          if (removeBtn) {
            removeBtn.addEventListener("click", function () {
              item.remove();
              refreshLivePreview();
            });
          }
          setEditable(item, true);
        }

        function addEntry(listEl, tpl) {
          var node = tpl.content.firstElementChild.cloneNode(true);
          listEl.appendChild(node);
          bindItem(node);
          refreshLivePreview();
        }

        function setupList(listId, addBtnId, tplId) {
          var listEl = document.getElementById(listId);
          var addBtn = document.getElementById(addBtnId);
          var tpl = document.getElementById(tplId);
          if (!listEl || !addBtn || !tpl) return;
          addBtn.addEventListener("click", function () { addEntry(listEl, tpl); });
        }

        setupList("aboutEntriesCreate", "addAboutCreate", "aboutEntryTemplateCreate");
        setupList("projectEntriesCreate", "addProjectCreate", "projectEntryTemplateCreate");
        setupList("experienceEntriesCreate", "addExperienceCreate", "experienceEntryTemplateCreate");

        function wireColorPair(hexId, pickerId) {
          var hexEl = document.getElementById(hexId);
          var pickEl = document.getElementById(pickerId);
          if (!hexEl || !pickEl) return;
          function fromHex() {
            var h = normHex(hexEl.value);
            pickEl.value = h;
            hexEl.value = h;
            refreshLivePreview();
          }
          function fromPick() {
            hexEl.value = normHex(pickEl.value);
            refreshLivePreview();
          }
          hexEl.addEventListener("input", fromHex);
          hexEl.addEventListener("change", fromHex);
          pickEl.addEventListener("input", fromPick);
          pickEl.addEventListener("change", fromPick);
        }

        wireColorPair("create-colorBg", "create-pick-colorBg");
        wireColorPair("create-colorText", "create-pick-colorText");
        wireColorPair("create-colorAccent", "create-pick-colorAccent");
        wireColorPair("create-colorCard", "create-pick-colorCard");

        var createThemeSel = document.getElementById("createThemePreset");
        if (createThemeSel) {
          createThemeSel.addEventListener("change", function () {
            var p = THEME_PRESETS[createThemeSel.value];
            if (!p) return;
            ["colorBg", "colorText", "colorAccent", "colorCard"].forEach(function (k) {
              var h = document.getElementById("create-" + k);
              var pick = document.getElementById("create-pick-" + k);
              if (h) h.value = p[k];
              if (pick) pick.value = p[k];
            });
            refreshLivePreview();
          });
        }

        function escHtml(s) {
          return String(s || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/\"/g, "&quot;");
        }

        function getRows(fd, a, b, c) {
          var aa = fd.getAll(a);
          var bb = fd.getAll(b);
          var cc = c ? fd.getAll(c) : [];
          var max = Math.max(aa.length, bb.length, c ? cc.length : 0);
          var out = [];
          for (var i = 0; i < max; i += 1) {
            var x = String(aa[i] || "").trim();
            var y = String(bb[i] || "").trim();
            var z = c ? String(cc[i] || "").trim() : "";
            if (!x && !y && !z) continue;
            out.push(c ? [x, y, z] : [x, y]);
          }
          return out;
        }

        function getModel() {
          var form = document.getElementById("createPortfolioForm");
          if (!form) return null;
          var fd = new FormData(form);
          return {
            fullName: fd.get("fullName") || "",
            role: fd.get("role") || "",
            headline: fd.get("headline") || "",
            heroText: fd.get("heroText") || "",
            shippingTitle: fd.get("shippingTitle") || "",
            shippingHeading: fd.get("shippingHeading") || "",
            shippingDescription: fd.get("shippingDescription") || "",
            aboutCards: getRows(fd, "aboutTitle", "aboutDescription"),
            projects: getRows(fd, "projectTitle", "projectPlatform", "projectDescription"),
            experiences: getRows(fd, "experiencePeriod", "experienceTitle", "experienceDescription"),
            styleTheme: fd.get("styleTheme") || "liquid-glass",
            colorBg: normHex(fd.get("colorBg") || "#05070d"),
            colorText: normHex(fd.get("colorText") || "#f5f8ff"),
            colorAccent: normHex(fd.get("colorAccent") || "#88b3ff"),
            colorCard: normHex(fd.get("colorCard") || "#151d30"),
            profileImageUrl: fd.get("profileImageUrl") || "",
            companyLogoUrl: fd.get("companyLogoUrl") || ""
          };
        }

        function renderPreviewHtml(m) {
          var bodyClass = "theme-style-" + escHtml(m.styleTheme || "liquid-glass");
          return (
            "<!doctype html><html><head><meta charset='utf-8'><meta name='viewport' content='width=device-width,initial-scale=1'>" +
            "<style>" +
            "body{font-family:Inter,Arial,sans-serif;margin:0;background:" + escHtml(m.colorBg) + ";color:" + escHtml(m.colorText) + ";padding:20px;}" +
            ".wrap{max-width:1000px;margin:0 auto}.hero{display:grid;grid-template-columns:1.2fr .8fr;gap:16px;margin:12px 0}.hero h1{margin:.2rem 0}.hero h1 span{display:block;font-weight:600;color:" + escHtml(m.colorAccent) + "}" +
            ".card{background:" + escHtml(m.colorCard) + ";border-radius:14px;padding:14px;border:1px solid rgba(255,255,255,.16)}" +
            ".grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}.stack{display:grid;gap:10px}" +
            ".eyebrow{font-size:.78rem;letter-spacing:.09em;text-transform:uppercase;color:" + escHtml(m.colorAccent) + ";margin:0}" +
            ".muted{opacity:.82}.avatar{width:84px;height:84px;border-radius:999px;object-fit:cover;border:2px solid " + escHtml(m.colorAccent) + ";display:block;margin:0 0 10px}" +
            ".projects-head{display:flex;justify-content:space-between;align-items:center;gap:10px}.logo{max-height:46px;max-width:120px;object-fit:contain}" +
            ".theme-style-glow h1,.theme-style-glow h2{letter-spacing:.01em;text-shadow:0 3px 0 rgba(0,0,0,.2)}" +
            "@media(max-width:860px){.hero{grid-template-columns:1fr}.grid{grid-template-columns:1fr}}" +
            "</style></head><body class='" + bodyClass + "'><div class='wrap'>" +
            "<section class='hero'><div>" +
            (m.profileImageUrl ? ("<img class='avatar' src='" + escHtml(m.profileImageUrl) + "' alt='Profile' />") : "") +
            "<p class='eyebrow'>" + escHtml(m.role) + "</p>" +
            "<h1>" + escHtml(m.fullName) + "<span>" + escHtml(m.headline) + "</span></h1>" +
            "<p class='muted'>" + escHtml(m.heroText) + "</p></div>" +
            "<aside class='card'><p class='eyebrow'>" + escHtml(m.shippingTitle) + "</p><h3>" + escHtml(m.shippingHeading) + "</h3><p class='muted'>" + escHtml(m.shippingDescription) + "</p></aside></section>" +
            "<section><h2>About</h2><div class='grid'>" +
            m.aboutCards.map(function (r) { return "<article class='card'><h4>" + escHtml(r[0]) + "</h4><p class='muted'>" + escHtml(r[1]) + "</p></article>"; }).join("") +
            "</div></section>" +
            "<section><div class='projects-head'><h2>Projects</h2>" +
            (m.companyLogoUrl ? ("<img class='logo' src='" + escHtml(m.companyLogoUrl) + "' alt='Logo' />") : "") +
            "</div><div class='grid'>" +
            m.projects.map(function (r) { return "<article class='card'><p class='eyebrow'>" + escHtml(r[1]) + "</p><h4>" + escHtml(r[0]) + "</h4><p class='muted'>" + escHtml(r[2]) + "</p></article>"; }).join("") +
            "</div></section>" +
            (m.experiences.length ? ("<section><h2>Experience</h2><div class='stack'>" +
              m.experiences.map(function (r) { return "<article class='card'><p class='eyebrow'>" + escHtml(r[0]) + "</p><h4>" + escHtml(r[1]) + "</h4><p class='muted'>" + escHtml(r[2]) + "</p></article>"; }).join("") +
              "</div></section>") : "") +
            "</div></body></html>"
          );
        }

        function refreshLivePreview() {
          var frame = document.getElementById("createLivePreviewFrame");
          if (!frame) return;
          var m = getModel();
          if (!m) return;
          frame.srcdoc = renderPreviewHtml(m);
        }

        var createForm = document.getElementById("createPortfolioForm");
        if (createForm) {
          createForm.addEventListener("input", refreshLivePreview);
          createForm.addEventListener("change", refreshLivePreview);
        }
        refreshLivePreview();
      })();
    </script>
  </body>
</html>

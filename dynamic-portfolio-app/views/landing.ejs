    <!-- ═══════════════════════════════════════════════════
         SCROLL ENGINE
         ═══════════════════════════════════════════════════ -->
    <script>
      (() => {
        /* ── Reduced-motion check ─────────────────────── */
        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;

        /* ── Nav background on scroll ─────────────────── */
        const nav = document.getElementById("ds-nav");
        let navSolid = false;

        /* ── Reveal elements ──────────────────────────── */
        const revealEls = document.querySelectorAll(".ds-reveal-line, .ds-reveal-word");
        const staggerEls = document.querySelectorAll("[data-ds-stagger]");
        const stepEls = document.querySelectorAll(".ds-step");
        const stepFill = document.getElementById("ds-steps-fill");

        /* ── Hero parallax ────────────────────────────── */
        const heroSection = document.getElementById("ds-hero");
        const heroContent = heroSection?.querySelector(".ds-hero__content");
        const heroHint = heroSection?.querySelector(".ds-hero__scroll-hint");

        /* ── Orbs parallax ────────────────────────────── */
        const orbs = document.querySelectorAll(".ds-bg__orb");

        /* ── IntersectionObserver for reveals ─────────── */
        if ("IntersectionObserver" in window) {
          const revealObserver = new IntersectionObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                const delay = parseInt(entry.target.dataset.delay || "0", 10);
                entry.target.style.transitionDelay = `${delay * 0.15}s`;
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.15, rootMargin: "0px 0px -60px 0px" }
          );
          revealEls.forEach((el) => revealObserver.observe(el));

          const staggerObserver = new IntersectionObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                const idx = parseInt(entry.target.dataset.dsStagger || "0", 10);
                entry.target.style.transitionDelay = `${idx * 0.12 + 0.1}s`;
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
          );
          staggerEls.forEach((el) => staggerObserver.observe(el));

          /* Steps progress */
          const stepObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-active");
                }
              });
            },
            { threshold: 0.4 }
          );
          stepEls.forEach((el) => stepObserver.observe(el));
        } else {
          revealEls.forEach((el) => el.classList.add("is-visible"));
          staggerEls.forEach((el) => el.classList.add("is-visible"));
          stepEls.forEach((el) => el.classList.add("is-active"));
        }

        /* ── Scroll-driven effects ────────────────────── */
        if (!prefersReducedMotion) {
          let ticking = false;

          const onScroll = () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => {
              const scrollY = window.scrollY;
              const vh = window.innerHeight;

              /* Nav scroll state */
              const shouldBeSolid = scrollY > 60;
              if (shouldBeSolid !== navSolid) {
                navSolid = shouldBeSolid;
                nav.classList.toggle("is-solid", navSolid);
              }

              /* Hero stays fully visible at all scroll positions */
              if (heroContent) heroContent.style.opacity = '';

              /* Orb parallax */
              orbs.forEach((orb, i) => {
                const rate = (i + 1) * 0.03;
                orb.style.transform = `translate3d(0, ${scrollY * rate}px, 0)`;
              });

              /* Steps progress bar */
              if (stepFill) {
                const stepsSection = document.getElementById("ds-steps");
                if (stepsSection) {
                  const rect = stepsSection.getBoundingClientRect();
                  const sectionProgress = Math.max(
                    0,
                    Math.min(1, (vh - rect.top) / (rect.height + vh * 0.3))
                  );
                  stepFill.style.width = `${sectionProgress * 100}%`;
                }
              }

              ticking = false;
            });
          };

          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll(); // initial
        } else {
          /* Reduced motion: show everything, no transforms */
          if (heroContent) {
            heroContent.style.transform = "none";
            heroContent.style.opacity = "1";
          }
          revealEls.forEach((el) => el.classList.add("is-visible"));
          staggerEls.forEach((el) => el.classList.add("is-visible"));
          stepEls.forEach((el) => el.classList.add("is-active"));
          if (stepFill) stepFill.style.width = "100%";
        }

        /* ── Browser showcase tabs (liquid sliding indicator) ── */
        const urlMap = {
          dark: 'liquilink.app/atharv-raj-sharma',
          light: 'liquilink.app/adarsh-sharma',
          analytics: 'liquilink.app/dashboard/analytics'
        };
        const tabsWrap = document.getElementById('ds-showcase-tabs');
        const indicator = document.getElementById('ds-tab-indicator');
        const tabEls = Array.from(document.querySelectorAll('.ds-showcase__tab'));

        /* Position the blue pill; on switch it first stretches to
           bridge the old + new tab (a liquid "reach"), then pulls in
           — water connecting and leaving. */
        let stretchTimer = 0;
        const placeIndicator = (tab, animate) => {
          if (!indicator || !tab) return;
          const targetLeft = tab.offsetLeft;
          const targetWidth = tab.offsetWidth;
          if (!animate) {
            indicator.style.transition = 'none';
            indicator.style.transform = 'translateX(' + targetLeft + 'px)';
            indicator.style.width = targetWidth + 'px';
            void indicator.offsetWidth;
            indicator.style.transition = '';
          } else {
            const curLeft = parseFloat(indicator.dataset.left || targetLeft);
            const curWidth = parseFloat(indicator.dataset.width || targetWidth);
            const bridgeLeft = Math.min(curLeft, targetLeft);
            const bridgeRight = Math.max(curLeft + curWidth, targetLeft + targetWidth);
            indicator.style.transform = 'translateX(' + bridgeLeft + 'px)';
            indicator.style.width = (bridgeRight - bridgeLeft) + 'px';
            clearTimeout(stretchTimer);
            stretchTimer = setTimeout(() => {
              indicator.style.transform = 'translateX(' + targetLeft + 'px)';
              indicator.style.width = targetWidth + 'px';
            }, 190);
          }
          indicator.dataset.left = targetLeft;
          indicator.dataset.width = targetWidth;
        };

        tabEls.forEach(tab => {
          tab.addEventListener('click', () => {
            const target = tab.dataset.tab;
            tabEls.forEach(t => t.classList.remove('is-active'));
            document.querySelectorAll('.ds-tab-panel').forEach(p => p.classList.remove('is-active'));
            tab.classList.add('is-active');
            document.querySelector(`.ds-tab-panel[data-panel="${target}"]`).classList.add('is-active');
            const urlEl = document.getElementById('ds-browser-url');
            if (urlEl) urlEl.textContent = urlMap[target] || '';
            placeIndicator(tab, true);
          });
        });

        /* Initial placement (after layout settles) + keep in sync on resize */
        const initialTab = document.querySelector('.ds-showcase__tab.is-active') || tabEls[0];
        requestAnimationFrame(() => placeIndicator(initialTab, false));
        window.addEventListener('load', () => placeIndicator(
          document.querySelector('.ds-showcase__tab.is-active') || tabEls[0], false));
        let resizeT = 0;
        window.addEventListener('resize', () => {
          clearTimeout(resizeT);
          resizeT = setTimeout(() => placeIndicator(
            document.querySelector('.ds-showcase__tab.is-active') || tabEls[0], false), 120);
        }, { passive: true });

        /* ── Browser window — reveal on page load (it's in the hero now) ── */
        const browser = document.getElementById('ds-browser');
        if (browser) {
          // Small delay so the CSS animation chain feels natural
          setTimeout(() => browser.classList.add('is-visible'), 200);
        }

        /* ── Theme toggle ────────────────────────────── */
        const themeToggle = document.getElementById('ds-theme-toggle');
        if (themeToggle) {
          const applyTheme = (theme) => {
            document.documentElement.setAttribute('data-theme', theme);
            try { localStorage.setItem('ll-theme', theme); } catch(e) {}
          };
          themeToggle.addEventListener('click', () => {
            const current = document.documentElement.getAttribute('data-theme');
            applyTheme(current === 'dark' ? 'light' : 'dark');
          });
        }

        /* ── Smooth scroll for anchor links ───────────── */
        document.querySelectorAll('a[href^="#ds-"]').forEach((link) => {
          link.addEventListener("click", (e) => {
            const target = document.querySelector(link.getAttribute("href"));
            if (target) {
              e.preventDefault();
              target.scrollIntoView({ behavior: "smooth", block: "start" });
            }
          });
        });
      })();
    </script>
    <script src="/liquid-glass.js?v=3"></script>


          <a class="ds-nav__link" href="/dashboard">Dashboard</a>
          <a class="ds-nav__link" href="/analytics">Analytics</a>
          <a class="ds-nav__link" href="/pricing">Pricing</a>
          <% } else { %>
          <a class="ds-nav__link" href="#ds-features">Features</a>
          <a class="ds-nav__link" href="#ds-steps">How it works</a>
          <a class="ds-nav__link" href="/pricing">Pricing</a>
          <% } %>
        </div>
        <div class="ds-nav__actions">
          <!-- iOS 26-style liquid glass theme toggle -->
          <button class="ds-theme-toggle" id="ds-theme-toggle" aria-label="Toggle dark / light mode" title="Toggle theme">
            <span class="ds-theme-toggle__icon ds-theme-toggle__icon--sun">☀</span>
            <span class="ds-theme-toggle__thumb"></span>
            <span class="ds-theme-toggle__icon ds-theme-toggle__icon--moon">☽</span>
          </button>
          <% if (currentUser) { %>
          <form action="/logout" method="POST" style="display:inline">
            <button type="submit" class="ds-nav__login-btn">Log out</button>
          </form>
          <a class="ds-nav__cta" href="/form.html">New portfolio</a>
          <% } else { %>
          <a class="ds-nav__login-btn" href="/login">Log in</a>
          <a class="ds-nav__cta" href="/signup">Get started free</a>
          <% } %>
        </div>
      </div>
    </nav>


<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LiquiLink | A Link-in-bio builder</title>
    <meta
      name="description"
      content="Create a polished link-in-bio page in minutes. Free to start; track views and link clicks from your dashboard."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="landing-page ll-landing">
    <div class="ll-landing__bg" aria-hidden="true"></div>
    <div class="ll-landing__orb ll-landing__orb--one" aria-hidden="true"></div>
    <div class="ll-landing__orb ll-landing__orb--two" aria-hidden="true"></div>
    <main>
      <section class="container ll-landing__hero">
        <div class="ll-landing__hero-grid">
          <div class="ll-landing__copy">
            <p class="eyebrow">Free to start</p>
            <h1>
              LiquiLink
              <span>Make your link-in-bio feel premium.</span>
            </h1>
            <p class="hero-text">
              One short form, one polished page, one shareable URL like
              <span class="mono">https://yoursite.com/your-name</span>. See how a
              finished page can look in the preview — then build your own in
              minutes.
            </p>
            <div class="landing-actions">
              <% if (currentUser) { %>
              <a class="btn btn-primary" href="/dashboard">
                <i class="fa-solid fa-table-columns" aria-hidden="true"></i>
                Go to my dashboard
              </a>
              <a class="btn btn-ghost" href="/form.html">Create new portfolio</a>
              <form action="/logout" method="POST">
                <button type="submit" class="btn btn-ghost">Logout</button>
              </form>
              <% } else { %>
              <a class="btn btn-primary" href="/signup">
                <i class="fa-solid fa-user-plus" aria-hidden="true"></i>
                Create your account
              </a>
              <a class="btn btn-ghost" href="/login">
                <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
                Log in to dashboard
              </a>
              <% } %>
            </div>
            <div class="ll-landing__quick-stats">
              <article>
                <h2>Fast setup</h2>
                <p>Fill a form and go live in minutes.</p>
              </article>
              <article>
                <h2>Built-in tracking</h2>
                <p>See views and click trends from dashboard.</p>
              </article>
            </div>
          </div>
          <div class="ll-landing__visual">
            <figure class="ll-landing__mockup">
              <img
                src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1400&q=82"
                width="1400"
                height="1050"
                alt="Example only: laptop on a desk with a web project on screen — not a specific LiquiLink profile"
                loading="eager"
                decoding="async"
              />
            </figure>
            <p class="ll-landing__caption">
              Example image (stock photo) for atmosphere — not a real user profile.
              Your published page uses your content, colors, and layout.
            </p>
          </div>
        </div>
      </section>

      <section class="container ll-landing__features" aria-label="Why LiquiLink">
        <div class="ll-landing__feature-grid">
          <article class="ll-landing__feature">
            <div class="ll-landing__feature-icon" aria-hidden="true">
              <i class="fa-solid fa-bolt"></i>
            </div>
            <h2>Ship in one sitting</h2>
            <p>
              Guided form, live-feeling preview, and a single URL you can drop
              into every bio. No CMS rabbit holes.
            </p>
          </article>
          <article class="ll-landing__feature">
            <div class="ll-landing__feature-icon" aria-hidden="true">
              <i class="fa-solid fa-wand-magic-sparkles"></i>
            </div>
            <h2>Looks intentional</h2>
            <p>
              Themes, typography, and layout options so the page matches your
              brand — not a generic link list.
            </p>
          </article>
          <article class="ll-landing__feature">
            <div class="ll-landing__feature-icon" aria-hidden="true">
              <i class="fa-solid fa-chart-line"></i>
            </div>
            <h2>Built-in analytics</h2>
            <p>
              Your dashboard shows page views and outbound link clicks so you
              can see what people actually use.
            </p>
          </article>
        </div>
      </section>

      <section class="container ll-landing__steps" aria-label="How it works">
        <h2>Build. Publish. Grow.</h2>
        <div class="ll-landing__steps-grid">
          <article class="ll-landing__step">
            <span>01</span>
            <h3>Create your page</h3>
            <p>Add your role, links, and highlights in one guided form.</p>
          </article>
          <article class="ll-landing__step">
            <span>02</span>
            <h3>Publish instantly</h3>
            <p>Get a clean shareable URL and update anytime from your dashboard.</p>
          </article>
          <article class="ll-landing__step">
            <span>03</span>
            <h3>Track engagement</h3>
            <p>Understand what visitors click and optimize your profile over time.</p>
          </article>
        </div>
      </section>

      <div class="container ll-landing__prose">
        <h2 id="what-is-liquilink">What is LiquiLink?</h2>
        <p>
          LiquiLink is a link-in-bio builder and lightweight portfolio host. You
          describe yourself once—projects, socials, contact—and we turn that into
          a fast page you can put everywhere your name appears.
        </p>

        <h2 id="about-the-product">About the product</h2>
        <p>
          There is no heavy CMS and no separate design tool to learn. You fill out
          a guided form, tune the look, and use your dashboard to update your
          public link when your details change. The free tier is easy to try; Pro
          unlocks deeper customization when you want it.
        </p>

        <h2 id="why-use-it">Why people use it</h2>
        <p>
          Many people juggle different links across profiles—work samples in one
          place, contact in another, older bios that never get updated. LiquiLink
          gives you one page that stays easier to keep current, with simple
          analytics so you know what visitors engage with.
        </p>
      </div>
    </main>
    <script>
      (() => {
        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;

        const revealTargets = document.querySelectorAll(
          ".ll-landing__feature, .ll-landing__step, .ll-landing__quick-stats article, .ll-landing__mockup"
        );

        if ("IntersectionObserver" in window) {
          const revealObserver = new IntersectionObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.2 }
          );
          revealTargets.forEach((el) => revealObserver.observe(el));
        } else {
          revealTargets.forEach((el) => el.classList.add("is-visible"));
        }

        const heroVisual = document.querySelector(".ll-landing__visual");
        if (heroVisual && !prefersReducedMotion) {
          let heroRect = null;
          let tiltRafId = null;
          let tiltX = "0deg";
          let tiltY = "0deg";

          const renderTilt = () => {
            heroVisual.style.setProperty("--tilt-x", tiltX);
            heroVisual.style.setProperty("--tilt-y", tiltY);
            tiltRafId = null;
          };

          const queueTiltRender = () => {
            if (tiltRafId) return;
            tiltRafId = window.requestAnimationFrame(renderTilt);
          };

          heroVisual.addEventListener("pointerenter", () => {
            heroRect = heroVisual.getBoundingClientRect();
          });

          heroVisual.addEventListener("pointermove", (event) => {
            heroRect ||= heroVisual.getBoundingClientRect();
            const px = (event.clientX - heroRect.left) / heroRect.width - 0.5;
            const py = (event.clientY - heroRect.top) / heroRect.height - 0.5;
            tiltX = `${py * -6}deg`;
            tiltY = `${px * 7}deg`;
            queueTiltRender();
          });
          heroVisual.addEventListener("pointerleave", () => {
            tiltX = "0deg";
            tiltY = "0deg";
            queueTiltRender();
          });
          window.addEventListener(
            "resize",
            () => {
              heroRect = null;
            },
            { passive: true }
          );
        }
      })();
    </script>
    <script src="/custom-cursor.js" defer></script>
  </body>
</html>

<section id="about" class="container section">
  <div class="section-title">
    <p>About</p>
    <h2>Get to know more about me.</h2>
  </div>
  <div class="about-grid about-layout--<%= portfolio.aboutLayout %>">
    <% portfolio.aboutCards.forEach((card) => { %>
    <article class="glass-card">
      <h3><%= card.title %></h3>
      <div data-read-more-container>
        <p class="text-clamp-3" data-read-more-text><%= card.description %></p>
        <button type="button" class="read-more-toggle" data-read-more-toggle hidden aria-expanded="false">
          Read more
        </button>
      </div>
    </article>
    <% }) %>
  </div>
</section>

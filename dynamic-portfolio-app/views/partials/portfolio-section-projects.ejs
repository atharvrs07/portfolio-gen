<section id="projects" class="container section">
  <div class="section-title section-title--projects">
    <div>
      <p>Featured Projects</p>
      <h2>Here's what I've done so far.</h2>
    </div>
    <% if (portfolio.companyLogoUrl) { %>
    <img
      class="projects-company-logo"
      src="<%= portfolio.companyLogoUrl %>"
      alt="Company logo"
      loading="lazy"
    />
    <% } %>
  </div>
  <div class="project-grid projects-layout--<%= portfolio.projectsLayout %>">
    <% portfolio.projects.forEach((project, idx) => { %>
    <article class="project-card">
      <div class="project-head">
        <p><%= String(idx + 1).padStart(2, "0") %></p>
        <span><%= project.platform %></span>
      </div>
      <h3><%= project.title %></h3>
      <div data-read-more-container>
        <p class="text-clamp-3" data-read-more-text><%= project.description %></p>
        <button type="button" class="read-more-toggle" data-read-more-toggle hidden aria-expanded="false">
          Read more
        </button>
      </div>
    </article>
    <% }) %>
  </div>
</section>

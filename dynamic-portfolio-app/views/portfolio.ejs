<!DOCTYPE html>
<html lang="en" class="portfolio-html font-scale--<%= portfolio.fontScale %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= portfolio.fullName %> | LiquiLink</title>
    <meta
      name="description"
      content="Portfolio of <%= portfolio.fullName %>, <%= portfolio.role %>."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="<%= portfolio.googleFontHref %>" rel="stylesheet" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body
    class="theme-<%= portfolio.theme || 'dark' %> theme-style-<%= portfolio.styleTheme || 'liquid-glass' %> portfolio-page portfolio-page-root layout-<%= portfolio.layoutVariant || 'default' %>"
    style="font-family: <%- portfolio.fontFamilyCss %>; --bg: <%= portfolio.colorBg %>; --text: <%= portfolio.colorText %>; --accent: <%= portfolio.colorAccent %>; --accent-2: <%= portfolio.colorAccent %>; --card-bg: <%= portfolio.colorCard %>;"
  >
    <div class="aurora aurora--one"></div>
    <div class="aurora aurora--two"></div>

    <% if (portfolio.showNavbar) { %>
    <header class="site-header">
      <nav class="container nav">
        <p class="brand"><%= portfolio.fullName %></p>
        <ul class="nav-links">
          <% portfolio.sectionOrder.forEach((sec) => { %>
            <% if (sec === 'about' && (portfolio.aboutCards || []).length > 0) { %>
          <li><a href="#about">About</a></li>
            <% } else if (sec === 'projects' && (portfolio.projects || []).length > 0) { %>
          <li><a href="#projects">Projects</a></li>
            <% } else if (sec === 'experience' && portfolio.hasExperience) { %>
          <li><a href="#experience">Experience</a></li>
            <% } %>
          <% }) %>
          <% if (portfolio.showFooterContact) { %>
          <li><a href="#contact">Contact</a></li>
          <% } %>
        </ul>
      </nav>
    </header>
    <% } %>

    <main>
      <% portfolio.sectionOrder.forEach((sec) => { %>
        <% if (sec === 'hero') { %>
          <%- include('partials/portfolio-section-hero', { portfolio }) %>
        <% } else if (sec === 'about' && (portfolio.aboutCards || []).length > 0) { %>
          <%- include('partials/portfolio-section-about', { portfolio }) %>
        <% } else if (sec === 'projects' && (portfolio.projects || []).length > 0) { %>
          <%- include('partials/portfolio-section-projects', { portfolio }) %>
        <% } else if (sec === 'experience' && portfolio.hasExperience) { %>
          <%- include('partials/portfolio-section-experience', { portfolio }) %>
        <% } %>
      <% }) %>
    </main>

    <footer id="contact" class="footer <%= portfolio.showFooterContact ? '' : 'footer--no-contact' %>">
      <% if (portfolio.showFooterContact) { %>
      <div class="container footer-content">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Get In Touch With Me.</h2>
          <p class="footer-note">
            Just mail me or visit my social media profiles and follow me!
          </p>
        </div>
        <div class="contact-links">
          <% if (portfolio.email) { %>
          <a href="<%= outboundHref('mailto:' + String(portfolio.email).trim()) %>"
            ><i class="fa-solid fa-envelope" aria-hidden="true"></i>Email</a
          >
          <% } %>
          <% if (portfolio.linkedin) { %>
          <a href="<%= outboundHref(String(portfolio.linkedin).trim()) %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-linkedin" aria-hidden="true"></i>LinkedIn</a
          >
          <% } %>
          <% if (portfolio.youtube) { %>
          <a href="<%= outboundHref(String(portfolio.youtube).trim()) %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-youtube" aria-hidden="true"></i>YouTube</a
          >
          <% } %>
          <% if (portfolio.instagram) { %>
          <a href="<%= outboundHref(String(portfolio.instagram).trim()) %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-instagram" aria-hidden="true"></i>Instagram</a
          >
          <% } %>
          <% if (portfolio.twitter) { %>
          <a href="<%= outboundHref(String(portfolio.twitter).trim()) %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-x-twitter" aria-hidden="true"></i>Twitter</a
          >
          <% } %>
          <% if (portfolio.github) { %>
          <a href="<%= outboundHref(String(portfolio.github).trim()) %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-github" aria-hidden="true"></i>GitHub</a
          >
          <% } %>
        </div>
      </div>
      <% } %>
      <p class="copyright">© 2026 <%= portfolio.fullName %>. All rights reserved.</p>
    </footer>
    <script>
      (() => {
        const pairs = Array.from(
          document.querySelectorAll("[data-read-more-container]")
        )
          .map((container) => ({
            text: container.querySelector("[data-read-more-text]"),
            toggle: container.querySelector("[data-read-more-toggle]")
          }))
          .filter((item) => item.text && item.toggle);

        if (!pairs.length) return;

        const needsReadMore = (text) => {
          const wasExpanded = text.classList.contains("text-expanded");
          if (wasExpanded) return true;

          const lineHeight =
            parseFloat(window.getComputedStyle(text).lineHeight) || 0;
          if (!lineHeight) {
            return text.scrollHeight > text.clientHeight + 1;
          }

          text.classList.remove("text-clamp-3");
          text.classList.add("text-expanded");
          const naturalHeight = text.scrollHeight;
          text.classList.remove("text-expanded");
          text.classList.add("text-clamp-3");

          return naturalHeight > lineHeight * 3 + 1;
        };

        const updateVisibility = () => {
          pairs.forEach(({ text, toggle }) => {
            if (text.classList.contains("text-expanded")) return;
            toggle.hidden = !needsReadMore(text);
          });
        };

        pairs.forEach(({ text, toggle }) => {
          toggle.addEventListener("click", () => {
            const willExpand = !text.classList.contains("text-expanded");
            text.classList.toggle("text-expanded", willExpand);
            text.classList.toggle("text-clamp-3", !willExpand);
            toggle.textContent = willExpand ? "Read less" : "Read more";
            toggle.setAttribute("aria-expanded", willExpand ? "true" : "false");
            updateVisibility();
          });
        });

        requestAnimationFrame(updateVisibility);
        window.addEventListener("resize", updateVisibility);
      })();
    </script>
    <script>
      (() => {
        const slug = "<%= portfolio.slug %>";
        const endpoint = "/api/analytics/engage";
        const visitorCookieName = "ll_vid";
        const sessionStorageKey = "ll_sid";
        const maxSessionIdLength = 64;

        const now = () => Date.now();
        let sessionStartMs = now();
        let lastActiveMs = sessionStartMs;
        let maxScrollPercent = 0;
        let sentFinal = false;

        function sanitizeId(raw) {
          const s = String(raw || "").replace(/[^a-zA-Z0-9_-]/g, "");
          return s.slice(0, maxSessionIdLength);
        }

        function getCookie(name) {
          const parts = String(document.cookie || "").split(";").map((item) => item.trim());
          for (const item of parts) {
            if (!item.startsWith(`${name}=`)) continue;
            return item.slice(name.length + 1);
          }
          return "";
        }

        function ensureVisitorId() {
          let id = sanitizeId(getCookie(visitorCookieName));
          if (id) return id;
          id = sanitizeId(`v_${Math.random().toString(36).slice(2)}${Date.now().toString(36)}`);
          document.cookie = `${visitorCookieName}=${id}; Max-Age=31536000; Path=/; SameSite=Lax`;
          return id;
        }

        function ensureSessionId() {
          try {
            const existing = sanitizeId(sessionStorage.getItem(sessionStorageKey));
            if (existing) return existing;
            const created = sanitizeId(
              `s_${Math.random().toString(36).slice(2)}${Date.now().toString(36)}`
            );
            sessionStorage.setItem(sessionStorageKey, created);
            return created;
          } catch {
            return sanitizeId(`s_${Date.now().toString(36)}`);
          }
        }

        const visitorId = ensureVisitorId();
        const sessionId = ensureSessionId();

        function updateScrollDepth() {
          const maxScrollable = document.documentElement.scrollHeight - window.innerHeight;
          if (maxScrollable <= 0) {
            maxScrollPercent = Math.max(maxScrollPercent, 100);
            return;
          }
          const current = Math.min(
            100,
            Math.max(0, (window.scrollY / maxScrollable) * 100)
          );
          if (current > maxScrollPercent) {
            maxScrollPercent = current;
          }
        }

        function calculateEngagedMs() {
          const activeDelta = now() - lastActiveMs;
          if (activeDelta < 30000) {
            return now() - sessionStartMs;
          }
          return lastActiveMs - sessionStartMs;
        }

        function sendEngagement(finalSend = false) {
          if (finalSend && sentFinal) return;
          const engagedMs = Math.max(0, Math.floor(calculateEngagedMs()));
          if (engagedMs < 1000 && !finalSend) return;

          const payload = {
            slug,
            visitorId,
            sessionId,
            engagedMs,
            scrollDepth: Math.round(maxScrollPercent * 100) / 100
          };

          const body = JSON.stringify(payload);
          if (navigator.sendBeacon) {
            const blob = new Blob([body], { type: "application/json" });
            navigator.sendBeacon(endpoint, blob);
          } else {
            fetch(endpoint, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body,
              keepalive: true
            }).catch(() => {});
          }

          if (finalSend) {
            sentFinal = true;
          } else {
            sessionStartMs = now();
          }
        }

        const activityHandler = () => {
          lastActiveMs = now();
        };

        ["click", "keydown", "touchstart", "mousemove", "scroll"].forEach((eventName) => {
          window.addEventListener(eventName, activityHandler, { passive: true });
        });
        window.addEventListener("scroll", updateScrollDepth, { passive: true });
        updateScrollDepth();

        setInterval(() => {
          sendEngagement(false);
        }, 30000);

        document.addEventListener("visibilitychange", () => {
          if (document.visibilityState === "hidden") {
            updateScrollDepth();
            sendEngagement(true);
          }
        });

        window.addEventListener("pagehide", () => {
          updateScrollDepth();
          sendEngagement(true);
        });
      })();
    </script>
    <script src="/custom-cursor.js" defer></script>
  </body>
</html>

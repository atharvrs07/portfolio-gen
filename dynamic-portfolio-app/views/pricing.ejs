<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pricing | LiquiLink</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <style>
      .pricing-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      }
      .pricing-card {
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 1rem;
        padding: 1rem;
        background: rgba(12, 20, 35, 0.55);
      }
      .pricing-card--active {
        border-color: rgba(126, 229, 255, 0.8);
        box-shadow: 0 0 0 1px rgba(126, 229, 255, 0.25) inset;
      }
      .pricing-price {
        margin: 0.5rem 0;
        font-size: 1.7rem;
        font-weight: 800;
      }
      .pricing-list {
        margin: 0.8rem 0 1rem;
        padding-left: 1.1rem;
      }
      .purchase-popup-overlay {
        position: fixed;
        inset: 0;
        background: rgba(6, 10, 18, 0.72);
        backdrop-filter: blur(10px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 999999;
        padding: 16px;
      }
      .purchase-popup-overlay.show {
        display: flex;
      }
      .purchase-popup {
        width: min(100%, 560px);
        border-radius: 24px;
        padding: 1.25rem;
        background: rgba(20, 26, 40, 0.98);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: #fff;
      }
      .purchase-popup-actions {
        display: flex;
        gap: 0.75rem;
      }
    </style>
    <script>
      const nextUrl = <%- JSON.stringify(next) %>;
      const userName = <%- JSON.stringify(currentUser ? currentUser.fullName : "") %>;
      const userEmail = <%- JSON.stringify(currentUser ? currentUser.email : "") %>;
      const selectedPlanOnLoad = <%- JSON.stringify(selectedPlan) %>;
      const prices = {
        plus: <%= plusPriceINR %>,
        pro: <%= proPriceINR %>
      };
      let checkoutPlan = selectedPlanOnLoad === "pro" ? "pro" : "plus";

      function openPurchasePopup(plan) {
        checkoutPlan = plan === "pro" ? "pro" : "plus";
        const nameEl = document.getElementById("purchasePlanName");
        const priceEl = document.getElementById("purchasePlanPrice");
        const popup = document.getElementById("purchasePopupOverlay");
        if (nameEl) nameEl.textContent = checkoutPlan === "pro" ? "LiquiLink Pro" : "LiquiLink Plus";
        if (priceEl) priceEl.textContent = "Rs " + prices[checkoutPlan] + " / 30 days";
        if (popup) popup.classList.add("show");
      }

      function closePurchasePopup() {
        const popup = document.getElementById("purchasePopupOverlay");
        if (popup) popup.classList.remove("show");
      }

      async function startRazorpayCheckout() {
        const button = document.getElementById("continueRazorpayBtn");
        if (typeof Razorpay === "undefined") {
          alert("Razorpay script failed to load. Please refresh and try again.");
          return;
        }

        try {
          if (button) {
            button.disabled = true;
            button.textContent = "Opening...";
          }

          const orderRes = await fetch("/api/razorpay/order", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ plan: checkoutPlan })
          });
          const orderJson = await orderRes.json();
          if (!orderJson.success) {
            throw new Error(orderJson.error || "Failed to create Razorpay order.");
          }

          const options = {
            key: orderJson.key_id,
            amount: orderJson.amount,
            currency: orderJson.currency,
            name: "LiquiLink",
            description:
              (checkoutPlan === "pro" ? "Pro" : "Plus") +
              " Plan - 30 Days (Rs " +
              prices[checkoutPlan] +
              ")",
            order_id: orderJson.order_id,
            prefill: { name: userName, email: userEmail },
            theme: { color: "#88b3ff" },
            handler: async function (response) {
              const verifyRes = await fetch("/payment/verify", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  razorpay_order_id: response.razorpay_order_id,
                  razorpay_payment_id: response.razorpay_payment_id,
                  razorpay_signature: response.razorpay_signature,
                  next: nextUrl
                })
              });
              const verifyJson = await verifyRes.json();
              if (!verifyJson.success) {
                throw new Error(verifyJson.error || "Payment verification failed.");
              }
              window.location.href = verifyJson.next || "/dashboard";
            },
            modal: {
              ondismiss: function () {
                if (button) {
                  button.disabled = false;
                  button.textContent = "Continue with Razorpay";
                }
              }
            }
          };

          const rzp = new Razorpay(options);
          rzp.on("payment.failed", function (payload) {
            const msg =
              payload && payload.error && payload.error.description
                ? payload.error.description
                : "Payment failed.";
            alert(msg);
            if (button) {
              button.disabled = false;
              button.textContent = "Continue with Razorpay";
            }
          });
          rzp.open();
        } catch (err) {
          alert(err.message || "Unable to start Razorpay checkout.");
          if (button) {
            button.disabled = false;
            button.textContent = "Continue with Razorpay";
          }
        }
      }
    </script>
  </head>
  <body class="pricing-page">
    <div class="aurora aurora--one"></div>
    <div class="aurora aurora--two"></div>

    <main class="container pricing-modal-stage">
      <div class="modal-backdrop">
        <section class="upgrade-modal" role="dialog" aria-modal="true">
          <p class="eyebrow">Choose your plan</p>
          <h1>Free, Plus, Pro</h1>
          <p class="hero-text">
            <%= reason === "builder" ? "Pro unlocks your drag-and-drop builder experience." : "Upgrade only when you need deeper customization." %>
          </p>

          <div class="pricing-grid">
            <article class="pricing-card <%= currentPlan === 'free' ? 'pricing-card--active' : '' %>">
              <p class="eyebrow">Free</p>
              <p class="pricing-price">Rs 0</p>
              <ul class="pricing-list">
                <li>1 portfolio</li>
                <li>Link-in-bio + portfolio hybrid</li>
                <li>Core content editing</li>
              </ul>
              <% if (currentPlan === "free") { %>
                <button class="btn btn-ghost" type="button" disabled>Current plan</button>
              <% } %>
            </article>

            <article class="pricing-card <%= currentPlan === 'plus' ? 'pricing-card--active' : '' %>">
              <p class="eyebrow">Plus</p>
              <p class="pricing-price">Rs <%= plusPriceINR %> <span style="font-size:0.9rem;font-weight:500;">/30d</span></p>
              <ul class="pricing-list">
                <li>Everything in Free</li>
                <li>Unlimited portfolios</li>
                <li>Theme, colors, layout, typography controls</li>
              </ul>
              <% if (currentPlan === "plus" || currentPlan === "pro") { %>
                <button class="btn btn-ghost" type="button" disabled>
                  <%= currentPlan === "plus" ? "Current plan" : "Included in Pro" %>
                </button>
              <% } else { %>
                <button class="btn btn-primary" type="button" onclick="openPurchasePopup('plus')">Choose Plus</button>
              <% } %>
            </article>

            <article class="pricing-card <%= currentPlan === 'pro' ? 'pricing-card--active' : '' %>">
              <p class="eyebrow">Pro</p>
              <p class="pricing-price">Rs <%= proPriceINR %> <span style="font-size:0.9rem;font-weight:500;">/30d</span></p>
              <ul class="pricing-list">
                <li>Everything in Plus</li>
                <li>Drag-and-drop website builder</li>
                <li>Custom section-based site publishing</li>
              </ul>
              <% if (currentPlan === "pro") { %>
                <button class="btn btn-ghost" type="button" disabled>Current plan</button>
              <% } else { %>
                <button class="btn btn-primary" type="button" onclick="openPurchasePopup('pro')">Choose Pro</button>
              <% } %>
            </article>
          </div>

          <div class="upgrade-modal-actions">
            <a href="/dashboard" class="btn btn-ghost">Back to dashboard</a>
          </div>
        </section>
      </div>
    </main>

    <div class="purchase-popup-overlay" id="purchasePopupOverlay">
      <div class="purchase-popup" role="dialog" aria-modal="true" aria-labelledby="purchasePopupTitle">
        <p class="eyebrow" id="purchasePlanName">LiquiLink Plus</p>
        <h2 id="purchasePopupTitle" style="margin-top:0;">Complete your upgrade</h2>
        <p id="purchasePlanPrice" style="margin-top:0.2rem;">Rs <%= plusPriceINR %> / 30 days</p>
        <p style="color:rgba(255,255,255,0.74);">
          Secure payment via Razorpay. Once verified, your plan is activated instantly.
        </p>
        <div class="purchase-popup-actions">
          <button type="button" class="btn btn-primary" id="continueRazorpayBtn" onclick="startRazorpayCheckout()">
            Continue with Razorpay
          </button>
          <button type="button" class="btn btn-ghost" onclick="closePurchasePopup()">Cancel</button>
        </div>
      </div>
    </div>
    <script src="/custom-cursor.js" defer></script>
  </body>
</html>